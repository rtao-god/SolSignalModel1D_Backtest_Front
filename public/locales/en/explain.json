  "modelsPage": {
    "header": {
      "title": "Models",
      "subtitle": "The signal is built from three layers: Day, Micro, and SL.",
      "linkLabel": "Detailed metrics are available on a dedicated page.",
      "linkButton": "Details"
    },
    "sections": {
      "overview": {
        "title": "Layer overview",
        "text": "Pipeline: Day -> Day+Micro -> Total (with SL overlay).",
        "table": {
          "headers": { "layer": "Layer", "role": "What it solves", "output": "Output" },
          "rows": [
            ["Day (Move+Dir)", "Is there a move and in which direction", "ProbUp / ProbFlat / ProbDown"],
            ["Micro (flat-only)", "Refines FLAT days", "Day+Micro"],
            ["SL", "Risk of SL before TP", "Total"]
          ]
        },
        "terms": [
          { "term": "Daily layer (Move + Dir)", "description": "Base prediction layer for movement and direction." },
          { "term": "Move (P(move))", "description": "Estimates whether a meaningful move will happen." },
          { "term": "Dir (P(up|move))", "description": "Chooses direction when movement is expected." },
          { "term": "Micro layer (flat-only)", "description": "Runs only for FLAT scenarios." },
          { "term": "SL risk layer", "description": "Estimates risk of hitting SL before TP." },
          { "term": "Total prediction", "description": "Final probabilities after all overlays." }
        ]
      },
      "daily": {
        "title": "Daily model",
        "text": "Outputs three classes: UP / FLAT / DOWN.",
        "table": {
          "headers": { "class": "Class", "condition": "Labeling condition" },
          "rows": [
            ["UP (2)", "entry * (1 + MinMove) is reached first"],
            ["DOWN (0)", "entry * (1 - MinMove) is reached first"],
            ["FLAT (1)", "+/-MinMove levels are not reached"]
          ]
        },
        "terms": [
          { "term": "Who defines FLAT", "description": "FLAT is defined by baseline-window conditions and runtime probabilities." },
          { "term": "UP / FLAT / DOWN", "description": "Three target classes for daily direction." },
          { "term": "MinMove", "description": "Threshold of meaningful daily movement." },
          { "term": "ATR (Average True Range)", "description": "Volatility indicator used for adaptive thresholds." },
          { "term": "RegimeDownFlag", "description": "Bearish market regime flag." },
          { "term": "HardRegimeIs2Flag", "description": "Hard market regime flag." },
          { "term": "Quiet day (technical)", "description": "No +/-MinMove touch inside baseline window." }
        ]
      },
      "micro": {
        "title": "Micro model",
        "text": "Refines FLAT days and does not replace the daily layer.",
        "notes": [
          "For UP/DOWN outputs, micro is not applied.",
          "For FLAT outputs, micro can refine directional tilt.",
          "This reduces loss of weak but consistent directional signals."
        ],
        "terms": [
          { "term": "When micro model is enabled", "description": "Only for FLAT predictions from the daily layer." },
          { "term": "MicroTruth", "description": "Micro-model target for FLAT days." },
          { "term": "Minimum data for micro", "description": "Requires enough flat days and both classes." },
          { "term": "Why micro layer exists", "description": "Captures weak but repeatable directional tilt inside sideways days." }
        ]
      },
      "sl": {
        "title": "SL model",
        "text": "Risk layer: probability of SL before TP.",
        "table": {
          "headers": { "parameter": "Parameter", "rule": "Current rule" },
          "rows": [
            ["Risk threshold", "SlHighDecision=true when p >= 0.55 and HighRisk"],
            ["TP for labels", "3%"],
            ["SL for labels", "5%"]
          ]
        },
        "terms": [
          { "term": "TP (Take Profit)", "description": "Target profit level for labeling." },
          { "term": "SL (Stop Loss)", "description": "Loss limit level for labeling." },
          { "term": "SlProb", "description": "Probability of SL before TP." },
          { "term": "SlHighDecision", "description": "Risk-day flag from the SL model." },
          { "term": "StrongSignal by MinMove", "description": "Strong-day feature used in SL logic." }
        ]
      },
      "aggregation": {
        "title": "Signal assembly",
        "text": "Each step refines the previous output.",
        "steps": [
          "Build Day probabilities.",
          "Apply micro overlay for FLAT days.",
          "Apply SL overlay and produce Total output."
        ],
        "terms": [
          { "term": "Day", "description": "Probabilities after the daily layer." },
          { "term": "Day+Micro", "description": "Probabilities after micro refinement." },
          { "term": "Total (Day+Micro+SL)", "description": "Final probabilities after SL overlay." },
          { "term": "ProbUp / ProbFlat / ProbDown", "description": "Three final probabilities, sum = 1.0." }
        ]
      }
    }
  },
  "branchesPage": {
    "header": {
      "title": "BASE / ANTI-D branches",
      "subtitle": "Compares plain execution vs anti-direction mode on risk days."
    },
    "sections": {
      "overview": {
        "title": "Why branches exist",
        "text": "These are different execution rules for the same forecast.",
        "table": {
          "headers": { "branch": "Branch", "howItWorks": "How it works", "whenUseful": "When useful" },
          "rows": [
            ["BASE", "Trades in model direction", "Reference signal quality"],
            ["ANTI-D", "Can flip direction on risk days", "Potential drawdown reduction"]
          ]
        },
        "terms": [
          { "term": "Policy", "description": "Rules for leverage, stake, TP/SL, and skip conditions." },
          { "term": "Branch", "description": "PnL execution mode inside one policy." },
          { "term": "BASE", "description": "Directly follows model direction." },
          { "term": "ANTI-D (anti-direction)", "description": "Direction flip when risk filters are met." }
        ]
      },
      "base": {
        "title": "BASE",
        "text": "Baseline reference point for evaluating protective overlays.",
        "terms": [
          { "term": "How direction is selected", "description": "UP -> long, DOWN -> short (with micro adjustments)." },
          { "term": "What BASE shows", "description": "Raw model quality without anti-direction." },
          { "term": "Why BASE matters", "description": "Without baseline, protection impact cannot be measured." }
        ]
      },
      "anti": {
        "title": "ANTI-D",
        "text": "Enabled only by risk conditions, not permanently.",
        "terms": [
          { "term": "Anti-direction", "description": "Direction swap long <-> short." },
          { "term": "RiskDay (SlHighDecision)", "description": "Primary trigger for ANTI-D activation." },
          { "term": "Where flip is applied", "description": "Applied before trade simulation at daily decision level." },
          { "term": "Why ANTI-D", "description": "Reduces heavy drawdowns at the cost of some upside." }
        ]
      },
      "conditions": {
        "title": "ANTI-D activation conditions",
        "text": "If one filter fails, branch behaves as BASE.",
        "table": {
          "headers": { "filter": "Filter", "threshold": "Threshold", "protection": "What it protects" },
          "rows": [
            ["SL risk day", "SlHighDecision=true", "No risk -> no flip"],
            ["MinMove", "0.5%..12%", "Removes noise and extremes"],
            ["Liquidation buffer", "liqAdversePct >= 2xMinMove", "Avoids thin liquidation buffer"]
          ]
        },
        "terms": [
          { "term": "SlHighDecision=true", "description": "Mandatory trigger for ANTI-D." },
          { "term": "MinMove in 0.5%-12% range", "description": "Filter for too-quiet and too-extreme days." },
          { "term": "Liquidation buffer >= 2xMinMove", "description": "Controls liquidation distance after flip." },
          { "term": "Valid leverage", "description": "ANTI-D requires finite leverage > 0." }
        ]
      },
      "usage": {
        "title": "How to read results",
        "text": "Compare branches as a metric package, not as one number.",
        "terms": [
          { "term": "PnL %", "description": "Total branch return." },
          { "term": "MaxDD %", "description": "Maximum drawdown on equity." },
          { "term": "Trade% / NoTrade%", "description": "Share of trading and skipped days." },
          { "term": "Policy Branch Mega", "description": "Main comparison table for policies and branches." }
        ]
      }
    }
  },
